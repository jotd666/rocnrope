screen_data_ptr_1:
	.long	0
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
screen_data_ptr_2:
	.long	0
	.endif
	
	.set	offset,0
	.ifdef  ECS_VERSION
	.set	increment,48	| ECS: 5 planes total
	.else
	.set	increment,40    | OCS/AGA: 4 planes total
	.endif
	
background_ptr:
	.long	0
playfield_drawn_screen_ptr:
	.long	0
playfield_displayed_screen_ptr:
	.long	0

	.ifdef	NONAGA_VERSION
	.if     NONAGA_VERSION==1
	.include	"sound_entries_ocs.68k"
	.else
	.include	"sound_entries.68k"
	.endif
	.else
	.include	"sound_entries.68k"	
