mid_screen_interrupt_count:
	.byte	0
	.align	2
system_vbr:
	.long	0


flip_flop:
	.byte	0


	.align	2

host_sprites:
	ds.b	8*SPRITE_SIZEOF
keyboard_table:
	ds.b	0x100

interrupt_mode:
	.word	0
	
	
last_known_m6809_pc:
	.word	-1
pause_flag:
	.word	0
frameskip:
	.word	0

tiles_row_flags:
	.skip	0x20
tiles_refresh_table:
