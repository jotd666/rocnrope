	ds.b	255
_end_of_ng_code:
		
  

	.align 2



palette:	
	.include "palette.68k"

	
	* on amiga, this file is included in mpatrol.68k file
	* so the assembler can optimize by using PC-relative addressing
	* whenever possible (and it does)
	.ifndef	RELEASE
	* easier to debug game to have memory aligned on 0x10000

	.ifne	OPT_ENABLE_LOGGING
	.section	.bsspublic

sprite_log_table:
	* 16 cluts, 256 tiles
	* a lot of combinations aren't used (fortunately!)
	.skip	NB_SPRITE_CLUTS*NB_POSSIBLE_SPRITES
character_log_table:
	* 16 cluts, 512 tiles
	* a lot of combinations aren't used (fortunately!)
	.skip	NB_TILE_CLUTS*NB_POSSIBLE_TILES
	.endif
	

log_ptr:
	.long	0

log_buffer:
	.skip	LOG_BUFFER_SIZE
log_buffer_end:
	.skip	16

cpu_log_enable:
	.word	0

	.endif



	.section	.datachip

* title
.macro	DECL_BITPLANES	bpoff_start,nb_planes
	.set	bpoff,\bpoff_start
	.rept	\nb_planes
	dc.w  0xe0+bpoff,0
	dc.w  0xe2+bpoff,0
	.set	bpoff,bpoff+4
	.endr
	.endm

	
.macro	DECL_COLORS	offset,nb_colors
	.set	colidx,\offset
	.rept	\nb_colors
	dc.w	color+(colidx*2),0
	.set	colidx,colidx+1
	.endr
	.endm
	
* game	
	.macro	DECL_EVEN_BITPLANES	bpoff_start,nb_planes
	.set	bpoff,\bpoff_start
	.rept	\nb_planes
	dc.w  bplpt+bpoff,0
	dc.w  bplpt+bpoff+2,0
	.set	bpoff,bpoff+8
	.endr
	.endm

	.macro	DECL_SPRITES
	.set	copper_sprite_start,sprpt+0
	.rept	16
	* 2 slots
	.word	copper_sprite_start,0
	.set	copper_sprite_start,copper_sprite_start+2
    .endr
	.endm

	.macro  DEF_SCROLL_ROWS	nb_rows
	.rept	\nb_rows
	.word	0x01+(y_start*256),0xFFFE
	.word	bplcon1
	.word	0
	.ifdef	NONAGA_VERSION
	DECL_BITPLANES	0,NB_BOB_PLANES
	.else
	DECL_EVEN_BITPLANES	4,4
	.endif
	.set	y_start,y_start+8
	.endr
	.endm 
	
blank_sprite:
	.long	0,0
	
blank_sound:
	ds.l	4
	
debug_copperlist:
	dc.w	bplcon0,0x200
	dc.w	color
debug_color:
	dc.w	0
	dc.l	-2
	


	
	* main copperlist
game_copperlist:

	* all sprites have the same palette no need to specify odd or even
	* on color bank 1
	
	* black color background plane


	* enable sprite colors now

	.word	0x01+((COPPER_Y_START)*256),0xFFFE
	.ifdef	NONAGA_VERSION
bobs_bitplanes:
tiles_bitplanes:
	DECL_BITPLANES	0,NB_BOB_PLANES
	.else
tiles_bitplanes:
	DECL_EVEN_BITPLANES	4,4
	.word	0x01+((COPPER_Y_START+2)*256),0xFFFE
bobs_bitplanes:
	DECL_EVEN_BITPLANES	0,4
	* set 0-scroll value for both plane sets
	.endif
	.word	bplcon1
reset_bplcon1_1:
	.word 	0

	.ifdef	NONAGA_VERSION
tiles_colors:
	DECL_COLORS	0,TOTAL_NB_COLORS
	.ifdef 	ECS_VERSION
bobs_colors:
	DECL_COLORS	16,TOTAL_NB_COLORS
	.endif
	.else
	* dual playfield. We could change so ocs & aga would have the same copperlist
	* but that's annoying work, AGA works, let's not touch it
tiles_colors:
	DECL_COLORS	16,TOTAL_NB_COLORS
bobs_colors:
	DECL_COLORS	0,TOTAL_NB_COLORS
	.endif


game_sprites:
	DECL_SPRITES
game_sprites_end:

	.word	0x01+((25)*256),0xFFFE
	.set	offset,0
sprite_control_words:
	.rept	8
	.word	spr+offset,0
	.word	spr+offset+2,0
	.set	offset,offset+8
	.endr
sprite_control_words_end:
	

	.set	y_start,COPPER_Y_START
intreq_block_game:
	.word	 intreq,0x8014  | call copper interrupt in the middle of a frame, also flag so copper interrupt knows that we're going to call copper int

 

	
	* pal limit
    .word  0xFFCF,0xFFFE       | PAL wait
	.set	y_start,0

	| no bobs from now on, get a LOT of drawing time
	.word	 intreq,0x8010
	.ifdef	NONAGA_VERSION
	.word	color,0
*status_bitplanes:
*	DECL_BITPLANES	0,NB_BOB_PLANES
	.endif


	* black color sprites
	*DECL_COLORS	16,16


	
     .long    -2					
	.ascii	"ENDCPLST"

	* aligning on 8 bytes so .align will work
	* in the next datachip sections
	.align	8
	
		.section .bsschip
		
	* AGA and OCS: one background buffer
bg_screen_buffer_1:
	.skip	BG_SCREEN_SIZE
	
	.ifdef	NONAGA_VERSION
	* OCS: background restore buffer
	* and optional extra background buffer for doublebuffer
	.skip	4
	* no need for the bob plane
background_restore_buffer:
	.skip	BG_SCREEN_PLANE_SIZE*NB_TILE_PLANES

	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
bg_screen_buffer_2:
	.skip	BG_SCREEN_SIZE
	.endif
	.else
	* AGA 1 or 2 front buffers
fg_screen_buffer_1:
	.skip	FG_SCREEN_SIZE
	.skip	FG_NB_BYTES_PER_ROW*12*3
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
fg_screen_buffer_2:
	.skip	FG_SCREEN_SIZE
	.skip	FG_NB_BYTES_PER_ROW*12*3
	.endif
	.endif


		